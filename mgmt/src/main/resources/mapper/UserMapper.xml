<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.managementsystem.mapper.UserMapper">

    <!-- 根据角色ID查询用户 -->
    <select id="selectByRoleId" resultType="com.example.managementsystem.entity.User">
        SELECT * FROM user
        WHERE role_id = #{roleId}
    </select>

    <!-- 根据用户名模糊查询 -->
    <select id="selectByUsernameLike" resultType="com.example.managementsystem.entity.User">
        SELECT * FROM user
        WHERE username LIKE CONCAT('%', #{username}, '%')
    </select>

    <!-- 根据用户名精确查询用户 -->
    <select id="selectByUsername" resultType="com.example.managementsystem.entity.User">
        SELECT * FROM user
        WHERE username = #{username} limit 1
    </select>

    <!-- 查询所有调解员 -->
    <select id="selectAllMediators" resultType="com.example.managementsystem.entity.User">
        SELECT u.* FROM user u
        INNER JOIN role r ON u.role_id = r.role_id
        WHERE r.role_name LIKE '%调解员%'
           OR r.role_name = '用户'
           OR r.role_name LIKE '%助理%'
    </select>

</mapper>